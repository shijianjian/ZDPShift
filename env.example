# ─────────────────────────────────────────────────────────────────────────────
# ZDPShift — optional overrides. The three backbones and SEA-RAFT are git
# submodules under third_party/ and resolve automatically; you normally do NOT
# need to set anything here. Override only if you keep them elsewhere.
# ─────────────────────────────────────────────────────────────────────────────
# export FOUNDATIONSTEREO_ROOT="$PWD/third_party/FoundationStereo"
# export IGEV_ROOT="$PWD/third_party/IGEV/IGEV-Stereo"
# export SEARAFT_ROOT="$PWD/third_party/SEA-RAFT"

# In-the-wild demo: directory of side-by-side 3D .mp4 clips (for rank_videos.py)
export SBS_VIDEO_DIR="$HOME/3d_movies"
